# Required: Metra GTFS API credentials.
# Apply at https://metra.com/metra-gtfs-api
METRA_API_TOKEN=your-api-token-here

# Optional: HTTP server bind address (only used with --sse / --http)
MCP_HOST=0.0.0.0
MCP_PORT=8080

# Optional: SQLite path for the /stats dashboard
METRA_STATS_DB=/var/lib/metra-mcp/stats.db

# Optional: enables the /copilot web chat UI by proxying to the Anthropic API.
# Without this, /copilot loads but cannot return answers.
ANTHROPIC_API_KEY=

# Optional: public URL the Anthropic API uses to call back into this MCP
# server. Auto-detected from the request when running behind a reverse proxy
# that sets X-Forwarded-Proto + Host. Override if auto-detection is wrong.
# METRA_PUBLIC_MCP_URL=https://metra.example.com/mcp

# Optional: how often (seconds) to re-check the published GTFS schedule.
# METRA_REFRESH_INTERVAL_SEC=21600

# Optional: TTL (seconds) for the in-memory cache of realtime feeds
# (positions / trip updates / alerts). 0 disables caching.
# METRA_RT_CACHE_TTL_SEC=20

# Optional: abuse guards for the /api/chat proxy (per client IP).
# METRA_CHAT_RATE_MAX=20
# METRA_CHAT_RATE_WINDOW_SEC=60
